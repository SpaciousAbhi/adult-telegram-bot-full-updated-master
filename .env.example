BOT_TOKEN=123456:replace-me
ADMIN_ID=123456789

# Use a MongoDB URI here. A PostgreSQL DATABASE_URL will not preserve Mongo users.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/adult_telegram_bot
MONGO_DATABASE=adult_telegram_bot

# Optional, only required for automatic source scanning/userbot login.
API_ID=
API_HASH=

# Optional runtime tuning.
POLL_INTERVAL_SECONDS=15
TASK_BATCH_LIMIT=20

