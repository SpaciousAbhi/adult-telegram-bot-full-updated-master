BOT_TOKEN=123456:replace-me
ADMIN_ID=123456789
ADMIN_IDS=123456789,987654321
OWNER_IDS=123456789,987654321

# Use a MongoDB URI here. A PostgreSQL DATABASE_URL will not preserve Mongo users.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/adult_telegram_bot
MONGO_DATABASE=adult_telegram_bot

# Optional: old PostgreSQL database used only to import registered users for broadcasts.
LEGACY_DATABASE_URL=set-your-old-sql-url-here

# Optional fallback. Userbot API ID/hash can also be added through /admin.
API_ID=
API_HASH=

# Optional runtime tuning.
POLL_INTERVAL_SECONDS=15
TASK_BATCH_LIMIT=20
SOURCE_HARVEST_LIMIT=100
SOURCE_COLLECT_SLEEP_SECONDS=1
